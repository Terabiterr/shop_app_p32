@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = "_Layout";
    ViewData["Title"] = "Delete ProductImage";
}

<form asp-controller="ProductImage" asp-action="DeleteImage" method="post">
    <div class="form-group">
        <label for="id">Id</label>
        <input name="id" for="id" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Delete</button>
</form>
